{
  "id": "ai_tool",
  "name": "AI-Powered Tool",
  "description": "CLI or web tool powered by local LLM via Ollama",
  "version": "1.0.0",
  "modules": ["api", "frontend"],
  "stack": {
    "backend": "express",
    "frontend": "react",
    "llm": "ollama"
  },
  "steps": [
    { "order": 1, "module": "api",      "action": "setup", "description": "Create API with Ollama integration" },
    { "order": 2, "module": "frontend", "action": "setup", "description": "Create chat/tool UI" }
  ],
  "successCriteria": ["server running", "LLM responds", "frontend loads"]
}
