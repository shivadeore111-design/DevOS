{
  "id": "saas_web_app",
  "name": "SaaS Web Application",
  "description": "Full-stack SaaS with auth, billing, dashboard",
  "version": "1.0.0",
  "modules": ["auth", "database", "api", "frontend", "billing"],
  "stack": {
    "frontend": "react",
    "backend": "express",
    "database": "postgres",
    "auth": "jwt",
    "billing": "stripe"
  },
  "steps": [
    { "order": 1, "module": "database", "action": "setup", "description": "Initialize database schema" },
    { "order": 2, "module": "auth",     "action": "setup", "description": "Setup JWT authentication" },
    { "order": 3, "module": "api",      "action": "setup", "description": "Create REST API endpoints" },
    { "order": 4, "module": "frontend", "action": "setup", "description": "Create React frontend" },
    { "order": 5, "module": "billing",  "action": "setup", "description": "Integrate billing system" }
  ],
  "successCriteria": ["server running", "auth endpoints respond", "frontend loads"]
}
