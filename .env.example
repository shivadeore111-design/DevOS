# ============================================================
# Aiden — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env
#
# .env is gitignored — NEVER commit real credentials.
# Aiden works fully offline with only Ollama configured;
# all cloud provider keys are optional fallbacks.
# ============================================================


# ── Core ─────────────────────────────────────────────────────

# Runtime environment (development | production | test)
NODE_ENV=production

# API server port (default: 4200)
MY_SERVER_PORT=4200

# Bind address (default: 127.0.0.1 — localhost only)
# Set to 0.0.0.0 only if you need remote/LAN access (e.g. headless server, WSL2)
# AIDEN_HOST=127.0.0.1

# CORS allowed origin (default: localhost only)
# Set to * to allow any origin when AIDEN_HOST=0.0.0.0
# AIDEN_CORS_ORIGIN=*

# Set to "true" to skip all confirmation prompts (CI / automation)
DEVOS_AUTO_APPROVE=false

# Set to "true" to run browser automation headless (no visible window)
DEVOS_HEADLESS=false

# ── Browser automation (playwrightBridge.ts) ─────────────────
# Run Chromium headless — set true for CI / server deployments (default: false)
# AIDEN_BROWSER_HEADLESS=false
# Navigation / action timeout in milliseconds (default: 15000 = 15s)
# AIDEN_BROWSER_TIMEOUT=15000

# Enable verbose debug logging
DEBUG=false

# Override where Aiden stores user data (default: %APPDATA%/Aiden)
# AIDEN_USER_DATA=C:\Users\you\AidenData

# Override the config directory
# AIDEN_CONFIG_DIR=C:\Users\you\AidenData\config

# Log file path (default: inside AIDEN_USER_DATA)
# AIDEN_LOG_FILE=C:\Users\you\AidenData\logs\aiden.log

# Internal API base URL (used by CLI to connect to the API server)
AIDEN_URL=http://localhost:4200


# ── Ollama (local inference — no key required) ───────────────

# Base URL for the Ollama API
# Use 127.0.0.1 (not localhost) on Windows to avoid IPv6 ECONNREFUSED
OLLAMA_HOST=http://127.0.0.1:11434

# Default chat model — run `ollama pull <model>` to install
# Recommended: mistral-nemo:12b (12 GB VRAM), qwen2.5:7b (8 GB), gemma2:2b (< 4 GB)
OLLAMA_MODEL=mistral-nemo:12b

# Alias for OLLAMA_HOST (both are read; OLLAMA_HOST takes precedence)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Ollama generation parameters (all optional) ──────────────
# These are passed as the `options` object to /api/chat.
# Omit any you don't want to override — Ollama uses its own defaults.

# Sampling temperature (0.0 = deterministic, 2.0 = very random; default ~0.8)
# OLLAMA_TEMPERATURE=0.7

# Context window size in tokens (default: model-dependent, often 2048–8192)
# Larger = more memory but longer coherent responses
# OLLAMA_CONTEXT_LENGTH=4096

# Number of GPU layers to offload (0 = CPU only, 999 = all layers on GPU)
# OLLAMA_NUM_GPU=999

# Number of CPU threads to use for inference (default: auto-detect)
# OLLAMA_NUM_THREAD=8

# Nucleus sampling cutoff — only tokens with cumulative probability ≤ top_p
# are considered (0.0–1.0; default ~0.9)
# OLLAMA_TOP_P=0.9

# Penalty for repeating tokens already in context (1.0 = no penalty)
# OLLAMA_REPEAT_PENALTY=1.1


# ── Providers (cloud LLM APIs — all optional) ────────────────

# Anthropic — Claude 3.5 Sonnet, Claude 3 Opus, etc.
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o, o1, o3, etc.
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq — free tier, fast Llama 3 / Mixtral inference
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI — Mistral Large/Small and Codestral models
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ElevenLabs — high-quality text-to-speech (voice layer)
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Vision model override for screen-reading / computer-use tasks
# Defaults to the active provider's vision model
DEVOS_VISION_MODEL=
DEVOS_CLAUDE_VISION_MODEL=


# ── Web Search ───────────────────────────────────────────────

# SearxNG — self-hosted privacy-respecting meta-search engine
# Start with: scripts\start-searxng.ps1  |  https://searxng.github.io/searxng/
SEARXNG_URL=http://localhost:8888

# Brave Search API — 2,000 free queries/month
# Get key: https://api.search.brave.com/register
BRAVE_SEARCH_API_KEY=


# ── Channels — Slack ─────────────────────────────────────────

# Create a Slack app at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_SIGNING_SECRET=

# Comma-separated list of channel IDs Aiden is allowed to read/post in
# Leave blank to allow all channels the bot is invited to
SLACK_ALLOWED_CHANNELS=


# ── Channels — Discord ───────────────────────────────────────

# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_TOKEN=

# Comma-separated guild (server) IDs to restrict Aiden to
DISCORD_ALLOWED_GUILDS=

# Comma-separated channel IDs Aiden is allowed to read/post in
DISCORD_ALLOWED_CHANNELS=


# ── Channels — Email (IMAP / SMTP) ───────────────────────────

# IMAP (incoming mail)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=you@gmail.com
EMAIL_IMAP_PASSWORD=

# SMTP (outgoing mail)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@gmail.com
EMAIL_SMTP_PASSWORD=

# Comma-separated list of sender addresses Aiden will process
# Leave blank to process all inbox mail (use with caution)
EMAIL_ALLOWED_SENDERS=

# How often to poll for new email, in milliseconds (default: 60000 = 1 min)
EMAIL_POLL_INTERVAL=60000


# ── Channels — Twilio (SMS / WhatsApp via Twilio) ────────────

# https://console.twilio.com
TWILIO_ACCOUNT_SID=AC
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1

# Comma-separated E.164 phone numbers Aiden will respond to
TWILIO_ALLOWED_NUMBERS=


# ── Channels — Signal ────────────────────────────────────────

# signal-cli REST API — https://github.com/bbernhard/signal-cli-rest-api
SIGNAL_CLI_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=+1

# Comma-separated phone numbers Aiden will respond to
SIGNAL_ALLOWED_NUMBERS=


# ── Channels — WhatsApp ──────────────────────────────────────

# whatsapp-web.js (QR-code auth, no API key needed for personal use)
# Path to persist WhatsApp session so you don't re-scan every restart
WHATSAPP_SESSION_PATH=./workspace/whatsapp-session

# Comma-separated phone numbers Aiden will respond to
WHATSAPP_ALLOWED_NUMBERS=

# WhatsApp Business API key (only if using the official Cloud API)
WHATSAPP_BUSINESS_API_KEY=


# ── Channels — BlueBubbles (iMessage via Mac) ────────────────

# https://bluebubbles.app — requires a Mac server running BlueBubbles
BLUEBUBBLES_URL=http://your-mac.local:1234
BLUEBUBBLES_PASSWORD=

# Comma-separated phone numbers / Apple IDs Aiden will respond to
BLUEBUBBLES_ALLOWED_NUMBERS=


# ── Channels — Webhook ───────────────────────────────────────

# Incoming webhook endpoint Aiden exposes for external triggers
WEBHOOK_URL=http://localhost:4200/webhook

# Shared secret for HMAC signature validation on incoming webhooks
WEBHOOK_SECRET=

# Comma-separated origins allowed to POST to the webhook endpoint
WEBHOOK_ALLOWED_ORIGINS=


# ── Voice ────────────────────────────────────────────────────

# Path to a local Whisper.cpp model file for offline STT
# Download models from: https://huggingface.co/ggerganov/whisper.cpp
WHISPER_MODEL_PATH=./models/ggml-base.en.bin

# Set to "true" to use VoxCPM for TTS instead of Edge TTS
USE_VOXCPM=false


# ── Testing & CI ─────────────────────────────────────────────

# Model used to judge/score agent responses in automated tests
JUDGE_MODEL=gpt-4o-mini

# Minimum pass rate (0–1) for test:audit to succeed
PASS_THRESHOLD=0.8

# Directory for test report output
REPORT_DIR=./tests/reports

# Set to "true" in CI environments
CI=false

# Blob storage token for test artifact uploads (Vercel Blob, etc.)
BLOB_READ_WRITE_TOKEN=


# ── Build & Release ──────────────────────────────────────────

# dotenv-vault encrypted key (only needed if using dotenv vault)
# DOTENV_KEY=dotenv://:key_...

# Windows code-signing certificate (for `npm run dist`)
# WINDOWS_CERTIFICATE_FILE=C:\path\to\cert.p12
# WINDOWS_CERTIFICATE_PASSWORD=
# WINDOWS_TIMESTAMP_SERVER=http://timestamp.sectigo.com


# ── Tier 1 Security Skills ───────────────────────────────────

# Have I Been Pwned — breach lookup for email addresses
# Subscription: https://haveibeenpwned.com/API/Key  ($3.50/month)
HIBP_API_KEY=

# urlscan.io — submit URLs for malware / phishing analysis
# Free account: https://urlscan.io  (no credit card required)
URLSCAN_API_KEY=

# Shodan — internet-wide port / banner scanning (next batch)
# Get key: https://account.shodan.io  (free tier available)
SHODAN_API_KEY=

# VirusTotal — file and URL reputation (next batch)
# Get key: https://www.virustotal.com/gui/my-apikey  (free tier)
VIRUSTOTAL_API_KEY=

# GreyNoise — classify IP addresses as benign/malicious (next batch)
# Get key: https://viz.greynoise.io/account  (community free tier)
GREYNOISE_API_KEY=

# NVD API (nvd.nist.gov — optional, for faster CVE lookups via cveapi skill)
# Free: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Censys (search.censys.io — free tier: 0.4 req/sec, 250 queries/month)
# Free account: https://search.censys.io/register
CENSYS_API_ID=
CENSYS_API_SECRET=


# ── Miscellaneous ────────────────────────────────────────────

# Default language for book/document processing features
BOOK_LANG=en

# Strict data-guard mode — blocks tools that could exfiltrate data
DEVOS_DATAGUARD_STRICT=false

# XDG config home override (Linux/WSL compatibility)
# XDG_CONFIG_HOME=~/.config


# ── Security & Sandbox ───────────────────────────────────────

# Docker sandbox mode for shell_exec and run_python tools.
#   off    — execute on host (default, no Docker required)
#   auto   — try Docker first, fall back to host if unavailable
#   strict — require Docker; error if not available or image fails to build
#
# Requires Docker Desktop (or Docker Engine on Linux).
# Install: https://www.docker.com/products/docker-desktop/
#
# When enabled, each tool call runs in a fresh container with:
#   --network=none  --memory=512m  --cpus=1  --read-only  --tmpfs /tmp
AIDEN_SANDBOX_MODE=off

# Stream live stdout lines from shell_exec / run_python / browser tools to the SSE client.
# Set to false to suppress progress output (useful for quiet/headless deployments).
# AIDEN_SHOW_TOOL_OUTPUT=true

# Optional: protect the OpenAI-compatible /v1 API with a Bearer token.
# Leave unset to allow unauthenticated local access (default for localhost).
# AIDEN_API_KEY=your-secret-key-here

# MCP Server mode (aiden mcp)
# Set to true to also expose shell/file-write/click tools via MCP (off by default for safety).
# MCP_ALLOW_DESTRUCTIVE=false
