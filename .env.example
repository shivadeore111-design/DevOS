# ============================================================
# DevOS — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
# ============================================================

# ── Ollama (local, no key needed) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral-nemo:12b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Web Search ───────────────────────────────────────────────
# SearxNG self-hosted (start with: scripts\start-searxng.ps1)
# Leave blank to use the default http://localhost:8888
SEARXNG_URL=http://localhost:8888

# Brave Search API — free tier: 2,000 queries/month
# Get key at: https://api.search.brave.com/register
BRAVE_SEARCH_API_KEY=

# ── AI Provider API Keys (optional — Ollama is default) ──────
# Groq — free, fast inference (llama3, mistral, etc.)
# https://console.groq.com
GROQ_API_KEY=

# OpenRouter — unified gateway to 100+ models
# https://openrouter.ai
OPENROUTER_API_KEY=

# Cerebras — ultra-fast inference
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# NVIDIA NIM — Llama, Mistral on NVIDIA infrastructure
# https://integrate.api.nvidia.com
NVIDIA_API_KEY=

# OpenAI — GPT-4o, o1, etc.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — Claude models
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google AI — Gemini models
# https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_API_KEY=

# ── Messaging Integrations (optional) ────────────────────────
# Slack Bot Token — get from https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Discord Bot Token — get from https://discord.com/developers
DISCORD_BOT_TOKEN=

# Telegram Bot Token — get from @BotFather
TELEGRAM_BOT_TOKEN=

# WhatsApp — no key needed (uses whatsapp-web.js + QR auth)

# Email (IMAP/SMTP)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com

# ── System Settings ──────────────────────────────────────────
DEVOS_DEBUG=true
DAEMON_AGENTS=1
DAEMON_POLL_MS=2000
DEVOS_AUTO_MODEL=true

# Stripe (for billing integrations)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
