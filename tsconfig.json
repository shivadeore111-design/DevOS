    "core/modelRouter.ts",
    "core/setupWizard.ts",
    "core/evolutionAnalyzer.ts",
    "core/executionLoop.ts",
    "core/doctor.ts",
    "coordination/commandGate.ts",
    "coordination/livePulse.ts",
    "bin/npx-init.ts",
    "memory/memoryLayers.ts",
    "security/dataGuard.ts",
    "security/browserVault.ts",
    "agents/types.ts",
    "agents/ceo.ts",
    "agents/verifier.ts",
    "agents/desktopAutomator.ts",
    "integrations/computerUse/screenAgent.ts",
    "integrations/computerUse/apiRegistry.ts",
