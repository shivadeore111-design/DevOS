{
  "name": "devos-ai",
  "version": "1.0.0",
  "description": "Autonomous AI Operating System — Local, Private, Free. Runs on your machine with Ollama.",
  "author": "Shiva Deore <devosxprojects@gmail.com>",
  "license": "Apache-2.0",
  "keywords": [
    "ai",
    "autonomous-agent",
    "agent",
    "personal-ai",
    "ollama",
    "local-ai",
    "devos",
    "llm",
    "ai-os",
    "self-hosted-ai",
    "open-source-ai",
    "mistral",
    "qwen",
    "builder"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "devos-ai": "./dist/bin/npx-init.js",
    "devos":    "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "dashboard-next/",
    "context/",
    "config/",
    "README.md",
    "LICENSE",
    "docker-compose.yml"
  ],
  "preferGlobal": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node index.ts",
    "run": "ts-node index.ts run",
    "daemon": "ts-node index.ts daemon",
    "status": "ts-node index.ts status",
    "build": "tsc --outDir dist",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0",
    "@types/sql.js": "^1.4.9",
    "axios": "^1.13.5",
    "chalk": "^5.6.2",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dockerode": "^4.0.9",
    "dotenv": "^17.3.1",
    "execa": "^8.0.1",
    "express": "^4.18.2",
    "imap-simple": "^5.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "playwright": "^1.58.2",
    "puppeteer": "^24.39.1",
    "qrcode-terminal": "^0.12.0",
    "sql.js": "^1.14.1",
    "tar-stream": "^3.1.8",
    "uuid": "^9.0.0",
    "whatsapp-web.js": "^1.26.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.3.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/tar-stream": "^3.1.4",
    "@types/uuid": "^9.0.0",
    "@vitest/ui": "^1.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
